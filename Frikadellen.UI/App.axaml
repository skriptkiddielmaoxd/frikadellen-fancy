<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Frikadellen.UI.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />

    <!-- Global colour palette -->
    <Style>
      <Style.Resources>
        <SolidColorBrush x:Key="BrandPrimary" Color="#6C5CE7" />
        <SolidColorBrush x:Key="BrandAccent" Color="#00CEC9" />
        <SolidColorBrush x:Key="BrandDanger" Color="#FF6B6B" />
        <SolidColorBrush x:Key="BrandSuccess" Color="#00B894" />
        <SolidColorBrush x:Key="BrandWarning" Color="#FDCB6E" />
        <SolidColorBrush x:Key="CardDark" Color="#2D3436" />
        <SolidColorBrush x:Key="CardLight" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfaceDark" Color="#1E272E" />
        <SolidColorBrush x:Key="SurfaceLight" Color="#F5F6FA" />
        <SolidColorBrush x:Key="TextPrimaryDark" Color="#DFE6E9" />
        <SolidColorBrush x:Key="TextPrimaryLight" Color="#2D3436" />
        <SolidColorBrush x:Key="SidebarDark" Color="#232B31" />
        <SolidColorBrush x:Key="SidebarLight" Color="#EBEDEF" />
      </Style.Resources>
    </Style>

    <!-- Global rounded button style -->
    <Style Selector="Button.pill">
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="24,10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!-- Card panel style -->
    <Style Selector="Border.card">
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="Margin" Value="6" />
      <Setter Property="BoxShadow" Value="0 2 8 0 #30000000" />
    </Style>

    <!-- Sidebar item style -->
    <Style Selector="Button.sidebar-item">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#B2BEC3" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button.sidebar-item:pointerover">
      <Setter Property="Background" Value="#30FFFFFF" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.sidebar-item.active">
      <Setter Property="Background" Value="#6C5CE7" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

  </Application.Styles>
</Application>
