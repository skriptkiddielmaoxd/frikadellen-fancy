<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             xmlns:m="using:Frikadellen.UI.Models"
             x:Class="Frikadellen.UI.Views.EventsView"
             x:DataType="vm:EventsViewModel">

  <UserControl.Styles>
    <Style Selector="Border.event-row">
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Transitions">
        <Transitions><BrushTransition Property="Background" Duration="0:0:0.2" /></Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.event-row:pointerover">
      <Setter Property="Background" Value="#0AFFFFFF" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">

    <!-- Page header -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,18">
      <StackPanel Grid.Column="0" Spacing="4">
        <TextBlock Text="Live Events"
                   FontSize="26" FontWeight="ExtraBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock Text="Real-time bot activity feed"
                   FontSize="13"
                   Foreground="{DynamicResource TextMutedBrush}" />
      </StackPanel>
      <Button Grid.Column="1"
              Classes="pill-ghost"
              Command="{Binding ClearCommand}"
              VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="7">
          <TextBlock Text="&#x1F5D1;" FontSize="13" VerticalAlignment="Center" />
          <TextBlock Text="Clear" FontSize="13" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- Event list -->
    <Border Grid.Row="1"
            Classes="card"
            Padding="0"
            ClipToBounds="True">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Events}"
                      Padding="8">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="m:EventItem">
              <Border Classes="event-row"
                      CornerRadius="12"
                      Padding="14,12"
                      Margin="0,0,0,2">
                <Grid ColumnDefinitions="Auto,*,Auto">

                  <!-- Avatar badge -->
                  <Border Grid.Column="0"
                          Width="38" Height="38"
                          CornerRadius="10"
                          Background="{DynamicResource BgElevatedBrush}"
                          Margin="0,0,12,0">
                    <TextBlock Text="{Binding Avatar}"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>

                  <!-- Content -->
                  <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding Type}"
                                 FontSize="11" FontWeight="SemiBold"
                                 Foreground="{DynamicResource AccentPrimaryBrush}" />
                      <TextBlock Text="{Binding TimeLabel}"
                                 FontSize="11"
                                 Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                    <TextBlock Text="{Binding Message}"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2" />
                  </StackPanel>

                  <!-- Expand arrow -->
                  <TextBlock Grid.Column="2"
                             Text="{Binding IsExpanded, Converter={x:Static vm:ExpandArrowConverter.Instance}}"
                             FontSize="12"
                             Foreground="{DynamicResource TextMutedBrush}"
                             VerticalAlignment="Center"
                             Margin="12,0,0,0" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

  </Grid>
</UserControl>
