<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             x:Class="Frikadellen.UI.Views.NotifierView"
             x:DataType="vm:NotifierViewModel">

  <UserControl.Styles>
    <Style Selector="Border.notif-card-1">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.0" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0" /><Setter Property="TranslateTransform.Y" Value="18" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.notif-card-2">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.08" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0" /><Setter Property="TranslateTransform.Y" Value="18" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.notif-card-3">
      <Style.Animations>
        <Animation Duration="0:0:0.45" Delay="0:0:0.16" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0" /><Setter Property="TranslateTransform.Y" Value="18" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /><Setter Property="TranslateTransform.Y" Value="0" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="0" Margin="0,0,8,0" MaxWidth="700">

      <!-- Page header -->
      <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Notifier"
                     FontSize="26" FontWeight="ExtraBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="Discord bot and webhook notifications"
                     FontSize="13"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                    VerticalAlignment="Center">
          <TextBlock Text="{Binding SaveStatus}"
                     FontSize="12"
                     Foreground="{DynamicResource AccentSuccessBrush}"
                     VerticalAlignment="Center" />
          <Button Classes="pill-primary" Command="{Binding SaveCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <TextBlock Text="&#x1F4BE;" FontSize="13" VerticalAlignment="Center" />
              <TextBlock Text="Save" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Discord Bot Token -->
      <Border Classes="card notif-card-1"
              Padding="0" ClipToBounds="True"
              RenderTransformOrigin="0.5,1" Opacity="0">
        <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
        <StackPanel>
          <Border Height="2">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Color="#E879F9" Offset="0" />
                <GradientStop Color="#22D3EE" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <StackPanel Spacing="14" Margin="22,18,22,22">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border Width="30" Height="30" CornerRadius="10" Background="#18E879F9">
                <TextBlock Text="&#x1F916;" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="Discord Bot" FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
            </StackPanel>
            <Border Classes="divider" />
            <StackPanel Spacing="8">
              <TextBlock Text="BOT TOKEN" Classes="section-title" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Classes="field"
                         Text="{Binding DiscordBotToken}"
                         PasswordChar="{Binding TokenPasswordChar}"
                         Watermark="Discord bot token"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1" Classes="icon-btn"
                        Command="{Binding ToggleTokenVisibilityCommand}">
                  <TextBlock Text="{Binding IsTokenVisible, Converter={x:Static vm:ShowHideConverter.Instance}}"
                             FontSize="16" />
                </Button>
              </Grid>
            </StackPanel>
            <StackPanel Spacing="8">
              <TextBlock Text="CHANNEL ID" Classes="section-title" />
              <TextBox Classes="field"
                       Text="{Binding DiscordChannelId}"
                       Watermark="Discord channel snowflake" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Webhook -->
      <Border Classes="card notif-card-2"
              Padding="0" ClipToBounds="True"
              RenderTransformOrigin="0.5,1" Opacity="0">
        <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
        <StackPanel>
          <Border Height="2">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Color="#22D3EE" Offset="0" />
                <GradientStop Color="#4ADE80" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <StackPanel Spacing="14" Margin="22,18,22,22">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border Width="30" Height="30" CornerRadius="10" Background="#1822D3EE">
                <TextBlock Text="&#x1F517;" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="Webhook" FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
            </StackPanel>
            <Border Classes="divider" />
            <StackPanel Spacing="8">
              <TextBlock Text="WEBHOOK URL" Classes="section-title" />
              <TextBox Classes="field"
                       Text="{Binding WebhookUrl}"
                       Watermark="https://discord.com/api/webhooks/..." />
            </StackPanel>
            <TextBlock Text="Flip alerts and session summaries will be sent to this webhook."
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Bot Commands reference -->
      <Border Classes="card notif-card-3"
              Padding="0" ClipToBounds="True"
              RenderTransformOrigin="0.5,1" Opacity="0">
        <Border.RenderTransform><TranslateTransform /></Border.RenderTransform>
        <StackPanel>
          <Border Height="2">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Color="#FB923C" Offset="0" />
                <GradientStop Color="#FB7185" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>
          <StackPanel Spacing="14" Margin="22,18,22,22">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border Width="30" Height="30" CornerRadius="10" Background="#18FB923C">
                <TextBlock Text="&#x1F4CB;" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="Bot Commands" FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
            </StackPanel>
            <Border Classes="divider" />

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,4,0,0">
              <Border Grid.Column="0" Grid.Row="0" CornerRadius="8" Padding="10,5"
                      Background="{DynamicResource BgElevatedBrush}" Margin="0,0,14,10">
                <TextBlock Text="!start" FontFamily="Consolas,Monospace"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentSuccessBrush}" />
              </Border>
              <TextBlock Grid.Column="1" Grid.Row="0" Text="Resume flip purchasing"
                         FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" Margin="0,0,0,10" />

              <Border Grid.Column="0" Grid.Row="1" CornerRadius="8" Padding="10,5"
                      Background="{DynamicResource BgElevatedBrush}" Margin="0,0,14,10">
                <TextBlock Text="!stop" FontFamily="Consolas,Monospace"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentDangerBrush}" />
              </Border>
              <TextBlock Grid.Column="1" Grid.Row="1" Text="Pause flip purchasing (bot stays connected)"
                         FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" Margin="0,0,0,10" />

              <Border Grid.Column="0" Grid.Row="2" CornerRadius="8" Padding="10,5"
                      Background="{DynamicResource BgElevatedBrush}" Margin="0,0,14,0">
                <TextBlock Text="!status" FontFamily="Consolas,Monospace"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentSecondaryBrush}" />
              </Border>
              <TextBlock Grid.Column="1" Grid.Row="2" Text="Show current state, purse, bot status and queue"
                         FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" />
            </Grid>
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
