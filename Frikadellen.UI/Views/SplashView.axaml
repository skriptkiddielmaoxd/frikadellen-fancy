<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             x:Class="Frikadellen.UI.Views.SplashView"
             x:DataType="vm:SplashViewModel">

  <UserControl.Styles>
    <!-- Logo bounce-in -->
    <Style Selector="Border.splash-logo">
      <Style.Animations>
        <Animation Duration="0:0:0.8" Easing="BounceEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="ScaleTransform.ScaleX" Value="0.3" />
            <Setter Property="ScaleTransform.ScaleY" Value="0.3" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="ScaleTransform.ScaleX" Value="1" />
            <Setter Property="ScaleTransform.ScaleY" Value="1" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Text fade-in -->
    <Style Selector="StackPanel.splash-text">
      <Style.Animations>
        <Animation Duration="0:0:0.5" Delay="0:0:0.4" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="12" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Progress bar container fade-in -->
    <Style Selector="Border.progress-container">
      <Style.Animations>
        <Animation Duration="0:0:0.5" Delay="0:0:0.6" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </UserControl.Styles>

  <Grid Background="{DynamicResource BgBaseBrush}">

    <!-- Soft radial glow in the background -->
    <Ellipse Width="700" Height="700"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">
      <Ellipse.Fill>
        <RadialGradientBrush>
          <GradientStop Color="#08E879F9" Offset="0" />
          <GradientStop Color="#00E879F9" Offset="1" />
        </RadialGradientBrush>
      </Ellipse.Fill>
    </Ellipse>

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="0">

      <!-- Logo -->
      <Border Classes="splash-logo"
              Width="100" Height="100"
              CornerRadius="28"
              Background="#15E879F9"
              BorderBrush="#30E879F9"
              BorderThickness="1.5"
              BoxShadow="0 0 60 0 #30E879F9"
              HorizontalAlignment="Center"
              Margin="0,0,0,28"
              RenderTransformOrigin="0.5,0.5"
              Opacity="0">
        <Border.RenderTransform><ScaleTransform /></Border.RenderTransform>
        <TextBlock Text="&#x25C6;" FontSize="42"
                   Foreground="{DynamicResource AccentPrimaryBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>

      <!-- App name + version -->
      <StackPanel Classes="splash-text"
                  HorizontalAlignment="Center"
                  Spacing="6"
                  Margin="0,0,0,36"
                  Opacity="0">
        <StackPanel.RenderTransform><TranslateTransform /></StackPanel.RenderTransform>
        <TextBlock Text="Frikadellen"
                   FontSize="36" FontWeight="ExtraBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding AppVersion}"
                   FontSize="14"
                   Foreground="{DynamicResource TextMutedBrush}"
                   HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Progress bar + status -->
      <Border Classes="progress-container"
              Width="300"
              Opacity="0">
        <StackPanel Spacing="12">
          <!-- Track -->
          <Border Height="4" CornerRadius="2"
                  Background="#20E879F9">
            <!-- Fill bar — shimmer effect via gradient -->
            <Border Height="4" CornerRadius="2"
                    HorizontalAlignment="Left"
                    Width="{Binding Progress, Converter={x:Static vm:ProgressToWidthConverter.Instance}}">
              <Border.Background>
                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                  <GradientStop Color="#E879F9" Offset="0" />
                  <GradientStop Color="#22D3EE" Offset="0.5" />
                  <GradientStop Color="#E879F9" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
            </Border>
          </Border>

          <TextBlock Text="{Binding StatusMessage}"
                     FontSize="12"
                     Foreground="{DynamicResource TextMutedBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

    </StackPanel>
  </Grid>
</UserControl>
