<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             xmlns:s="using:Frikadellen.UI.Services"
             x:Class="Frikadellen.UI.Views.ConsoleView"
             x:DataType="vm:ConsoleViewModel">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Header -->
    <Border Grid.Row="0"
            Background="{DynamicResource BgCardBrush}"
            CornerRadius="16,16,0,0"
            Padding="22,16"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1,1,1,0"
            Margin="0,0,0,0">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Console"
                     FontSize="22" FontWeight="ExtraBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="Rust backend stdout / stderr"
                     FontSize="13"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                    VerticalAlignment="Center">
          <Button Classes="pill-primary"
                  Command="{Binding StartCommand}"
                  IsEnabled="{Binding !IsRunning}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <TextBlock Text="&#x25B6;" FontSize="12" VerticalAlignment="Center" />
              <TextBlock Text="Start" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Classes="pill-danger"
                  Command="{Binding StopCommand}"
                  IsEnabled="{Binding IsRunning}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <TextBlock Text="&#x23F9;" FontSize="12" VerticalAlignment="Center" />
              <TextBlock Text="Stop" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Classes="pill-ghost"
                  Command="{Binding ClearCommand}">
            <TextBlock Text="Clear" FontSize="13" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Console output -->
    <Border Grid.Row="1"
            Background="#0A0808"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1,0,1,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Lines}"
                      Padding="16,12">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="s:ConsoleLineItem">
              <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,1">
                <TextBlock Text="{Binding TimeLabel}"
                           FontFamily="Consolas,Monospace"
                           FontSize="11"
                           Foreground="#4B5563"
                           VerticalAlignment="Center"
                           MinWidth="60" />
                <TextBlock Text="{Binding Text}"
                           FontFamily="Consolas,Monospace"
                           FontSize="12"
                           Foreground="{Binding Foreground}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- Footer: exe path input -->
    <Border Grid.Row="2"
            Background="{DynamicResource BgCardBrush}"
            CornerRadius="0,0,16,16"
            Padding="22,14"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1,0,1,1">
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 Classes="field"
                 Text="{Binding ExePath}"
                 Watermark="Path to frikadellen binary (or leave blank to auto-detect)"
                 Margin="0,0,12,0" />
        <TextBlock Grid.Column="1"
                   Text="{Binding IsRunning, StringFormat='{}Running: {0}'}"
                   FontSize="12"
                   Foreground="{DynamicResource TextMutedBrush}"
                   VerticalAlignment="Center" />
      </Grid>
    </Border>

  </Grid>
</UserControl>
