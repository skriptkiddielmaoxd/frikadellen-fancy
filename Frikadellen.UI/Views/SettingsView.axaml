<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frikadellen.UI.ViewModels"
             x:Class="Frikadellen.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="20" Margin="4" MaxWidth="600">

      <TextBlock Text="Settings" FontSize="26" FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryDark}" Margin="0,0,0,4" />

      <!-- Token -->
      <StackPanel Spacing="4">
        <TextBlock Text="Token" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryDark}" />
        <TextBox Text="{Binding Token}" Watermark="Enter your bot token"
                 PasswordChar="●" CornerRadius="8" Padding="10,8"
                 ToolTip.Tip="Your authentication token (stored locally)" />
      </StackPanel>

      <!-- Allowed Channel ID -->
      <StackPanel Spacing="4">
        <TextBlock Text="Allowed Channel ID" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryDark}" />
        <TextBox Text="{Binding AllowedChannelId}" Watermark="e.g. 123456789"
                 CornerRadius="8" Padding="10,8"
                 ToolTip.Tip="Discord channel ID to listen on" />
      </StackPanel>

      <!-- Publish Path -->
      <StackPanel Spacing="4">
        <TextBlock Text="Publish Path" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryDark}" />
        <TextBox Text="{Binding PublishPath}" Watermark="e.g. ./output"
                 CornerRadius="8" Padding="10,8"
                 ToolTip.Tip="Path where published artefacts are written" />
      </StackPanel>

      <!-- Save -->
      <StackPanel Orientation="Horizontal" Spacing="14">
        <Button Classes="pill" Background="{DynamicResource BrandPrimary}"
                Foreground="White" Command="{Binding SaveCommand}"
                ToolTip.Tip="Persist settings to config/ui-settings.json">
          <TextBlock Text="Save" FontWeight="Bold" />
        </Button>
        <TextBlock Text="{Binding SaveStatusText}" VerticalAlignment="Center"
                   Foreground="{DynamicResource BrandSuccess}" FontSize="13" />
      </StackPanel>

      <!-- Explanation -->
      <Border Classes="card" Background="{DynamicResource CardDark}" Margin="0,12,0,0">
        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#B2BEC3"
                   Text="Settings are persisted to ./config/ui-settings.json relative to the executable. This is a prototype-only storage mechanism; no secrets leave this machine." />
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
